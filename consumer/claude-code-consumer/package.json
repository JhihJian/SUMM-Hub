{
  "name": "summ-hub-typescript-consumer",
  "version": "1.0.0",
  "description": "SUMM-Hub TypeScript Consumer - 订阅 NATS 消息，调用 Claude Code 执行任务",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "docker compose -f test-integration/docker-compose.test.yml up --abort-on-container-exit"
  },
  "dependencies": {
    "nats": "^2.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
