# Feishu-Connector 环境配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 必需配置
# ============================================

# 飞书应用 App ID (从飞书开放平台获取)
FEISHU_APP_ID=cli_xxxxxxxxxxxx

# 飞书应用 App Secret (从飞书开放平台获取)
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# NATS 配置 (必需 - 连接已部署的 NATS)
# ============================================

# NATS 服务器地址
# - 宿主机服务 (Docker 环境): nats://host.docker.internal:6422
# - Docker 网络: nats://nats:4222
# - 生产环境: nats://nats.example.com:4222
NATS_URL=nats://host.docker.internal:6422

# ============================================
# 消息 Subject 配置 (可自定义)
# ============================================

# AI 输入消息 Subject (发送给 AI 的消息)
# 格式: summ.<domain>.input
INPUT_SUBJECT=summ.ai.input

# AI 输出消息 Subject (AI 响应的消息)
# 格式: summ.<domain>.output
OUTPUT_SUBJECT=summ.ai.output

# ============================================
# 触发器配置
# ============================================

# Session ID 前缀 (用于指定会话)
# 用户消息: "#session-abc 你好" → session_id = "abc"
TRIGGER_PREFIX=#

# ============================================
# Bot 配置
# ============================================

# Bot 的 open_id (用于群聊 @mention 检测)
# 可选，如果不填会自动获取
BOT_OPEN_ID=

# ============================================
# 日志配置
# ============================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Docker 镜像配置
# ============================================

# 镜像标签
IMAGE_TAG=latest
